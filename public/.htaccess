# ── Bubbles Enterprise — Apache config for Next.js static export ─────────────
# Servidor: DirectAdmin / Apache — cronos.intelsrv.net
# Next.js `output: "export"` gera slug.html + pasta slug/ com arquivos internos.
# Prioridade: arquivo físico real > slug.html > strip trailing slash

Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# ── 0. Servir arquivos físicos reais direto (CSS, JS, imagens, PHP, JSON) ─────
# Exclui pastas — pastas são tratadas pelas regras abaixo
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ── 1. Prioridade para slug.html sobre pasta de mesmo nome ────────────────────
# /gallery/ ou /gallery → serve gallery.html se existir
# Remove trailing slash internamente e serve o .html (sem redirect externo)
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ── 2. Subpáginas: /contact/emergency → contact/emergency.html ────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ $1.html [L]

# ── 3. Remove trailing slash com redirect 301 (SEO) ──────────────────────────
# Só para URLs onde o .html NÃO existe (caso raro)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Força HTTPS por 1 ano — Google ranqueia melhor sites com HSTS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Bloqueia iframes de outros domínios (clickjacking)
    Header always set X-Frame-Options "DENY"

    # Bloqueia MIME sniffing — evita que browser execute JS disfarçado de imagem
    Header always set X-Content-Type-Options "nosniff"

    # Não vaza URL completa ao clicar em link externo
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Desativa acesso a câmera, microfone, GPS — nenhum desses é usado no site
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"

    # COOP — isola a janela do site de pop-ups de outros domínios (clickjacking/XSS via window.opener)
    Header always set Cross-Origin-Opener-Policy "same-origin"

    # XSS Protection — legado mas ainda respeitado por alguns scanners
    Header always set X-XSS-Protection "1; mode=block"

    # Content Security Policy — controla de onde o browser pode carregar recursos
    # Permite: próprio domínio, Google Fonts, Web3Forms (formulário), inline styles/scripts (Next.js precisa)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.clarity.ms https://scripts.clarity.ms https://connect.facebook.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self'; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com https://*.clarity.ms https://www.facebook.com; object-src 'none'; frame-ancestors 'none'; form-action 'self'; base-uri 'self';"
</IfModule>

# ── Gzip compression — reduz tamanho de HTML/CSS/JS na transferência ──────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/ld+json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2 font/woff
</IfModule>

# ── Cache static assets ───────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html                "access plus 0 seconds"
    ExpiresByType text/css                 "access plus 1 year"
    ExpiresByType application/javascript   "access plus 1 year"
    ExpiresByType image/jpeg               "access plus 1 year"
    ExpiresByType image/png                "access plus 1 year"
    ExpiresByType image/webp               "access plus 1 year"
    ExpiresByType image/avif               "access plus 1 year"
    ExpiresByType image/svg+xml            "access plus 1 year"
    ExpiresByType application/json        "access plus 1 hour"
    ExpiresByType font/woff2               "access plus 1 year"
    ExpiresByType font/woff                "access plus 1 year"
</IfModule>
